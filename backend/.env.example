# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/equipment_control

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=5242880

# App
APP_NAME=Equipment Control System
DEBUG=true
